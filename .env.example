# =============================================================================
# Bio AI Platform — Boltz-2 Service
# Copy to .env and fill in values
# =============================================================================

# App
APP_ENV=development  # development | staging | production

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-dashboard

# Database (Supabase PostgreSQL direct connection)
# Use the "Direct connection" string from Supabase Dashboard > Settings > Database
DATABASE_URL=postgresql+psycopg://postgres.xxx:password@db.xxx.supabase.co:5432/postgres

# ---------------------------------------------------------------------------
# Azure Blob Storage
# ---------------------------------------------------------------------------
BLOB_BACKEND=local
# BLOB_BACKEND=azure
# AZURE_STORAGE_ACCOUNT_URL=https://xxx.blob.core.windows.net
# AZURE_STORAGE_ACCOUNT_NAME=xxx
# AZURE_STORAGE_ACCOUNT_KEY=xxx
# AZURE_STORAGE_CONNECTION_STRING=...

# ---------------------------------------------------------------------------
# Azure Service Bus
# ---------------------------------------------------------------------------
QUEUE_BACKEND=local
# QUEUE_BACKEND=azure
# SERVICE_BUS_CONNECTION_STRING=...

# ---------------------------------------------------------------------------
# Boltz-2 Settings
# ---------------------------------------------------------------------------
AZURE_INPUT_CONTAINER=boltz2-inputs
AZURE_RESULTS_CONTAINER=boltz2-results
SERVICE_BUS_QUEUE_NAME=boltz2-predict-jobs

BOLTZ2_BIN=boltz
BOLTZ2_CACHE_DIR=/cache
BOLTZ2_RUN_TIMEOUT_SECONDS=14400
BOLTZ2_DEVICES=1
MSA_SERVER_URL=https://api.colabfold.com

# ---------------------------------------------------------------------------
# Domain rules
# ---------------------------------------------------------------------------
AUTO_APPROVE_DOMAINS=["shaperon.com"]

# ---------------------------------------------------------------------------
# ACA Deployment (used by scripts/aca_deploy.sh)
# ---------------------------------------------------------------------------
# ACA_SUBSCRIPTION_ID=
# ACA_RESOURCE_GROUP=
# ACA_WORKER_JOB_NAME=boltz2-worker
# ACR_LOGIN_SERVER=shaperon.azurecr.io
# ACR_USERNAME=
# ACR_PASSWORD=
# CONTAINERAPPS_ENV=
