# =============================================================================
# Bio AI Platform — Boltz-2 Service
# Copy to .env and fill in values.
#
# 이 파일은 두 용도로 쓰인다:
#   (1) 런타임 설정: API / Worker 프로세스가 Boltz2Settings로 로드
#   (2) 배포 스크립트: scripts/aca_deploy.sh 가 쉘 변수로 읽음 (하단 섹션)
#
# 따옴표 규칙:
#   - 단일따옴표 '...': 리터럴 보존 (변수 확장 없음). URL/크리덴셜/JSON 에 권장
#   - 따옴표 없음: 단순 식별자 (영숫자/._@-만)
#   - 값에 ; " ' [ ] & | < > ( ) { } # $ * ? ~ ` 포함 시 반드시 quote
#     ex) SERVICE_BUS connection string 에는 ; 가 들어있어 quote 없으면 잘림
# =============================================================================

# -----------------------------------------------------------------------------
# [런타임] 앱 공통
# -----------------------------------------------------------------------------
APP_ENV=development  # development | staging | production
AUTO_APPROVE_DOMAINS='["shaperon.com"]'   # JSON. 단일따옴표 필수 (내부 " 보존)

# -----------------------------------------------------------------------------
# [런타임] Supabase / Database
# -----------------------------------------------------------------------------
SUPABASE_URL='https://xxx.supabase.co'
SUPABASE_ANON_KEY='eyJ...'
SUPABASE_JWT_SECRET='your-jwt-secret-from-supabase-dashboard'

# Supabase Session Pooler 권장. platform_core.db가 postgresql:// → postgresql+psycopg:// 로 자동 정규화.
DATABASE_URL='postgresql://postgres.xxx:password@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres'

# -----------------------------------------------------------------------------
# [런타임] Blob Storage 백엔드
# -----------------------------------------------------------------------------
BLOB_BACKEND=local   # local | azure
# BLOB_BACKEND=azure
# AZURE_STORAGE_ACCOUNT_URL='https://nanomapstorage.blob.core.windows.net'
# AZURE_STORAGE_ACCOUNT_NAME=nanomapstorage
# AZURE_STORAGE_ACCOUNT_KEY='xxx'

# -----------------------------------------------------------------------------
# [런타임] Queue 백엔드
# -----------------------------------------------------------------------------
QUEUE_BACKEND=local  # local | azure
# QUEUE_BACKEND=azure
# ';' 구분자 포함 → 단일따옴표 필수
# SERVICE_BUS_CONNECTION_STRING='Endpoint=sb://nanobodydsb897d0b.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=xxx'

# -----------------------------------------------------------------------------
# [런타임] Boltz-2 Worker 실행 파라미터
# -----------------------------------------------------------------------------
BOLTZ2_BIN=boltz
BOLTZ2_CACHE_DIR=/cache
BOLTZ2_RUN_TIMEOUT_SECONDS=0  # 0 = 무한 대기 (Service Bus lock은 24h까지 자동 연장)
BOLTZ2_DEVICES=1
MSA_SERVER_URL='https://api.colabfold.com'

# -----------------------------------------------------------------------------
# [런타임] ACA 로그 스트리밍 (API가 Worker Job 로그를 프록시할 때 사용)
# -----------------------------------------------------------------------------
# ACA_SUBSCRIPTION_ID=<azure subscription id>
# ACA_RESOURCE_GROUP=nanobody-designer-897d0b-rg
# ACA_WORKER_JOB_NAME=boltz2-worker

# -----------------------------------------------------------------------------
# [런타임] Gmail SMTP (잡 상태 알림)
# -----------------------------------------------------------------------------
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=''   # Gmail 앱 비밀번호는 공백 포함 → 단일따옴표 필수
SMTP_FROM_EMAIL=

# =============================================================================
# [배포] scripts/aca_deploy.sh 실행 시 필요한 쉘 변수
#
# 로컬에서 `./scripts/aca_deploy.sh` 를 돌리려면 아래 값을 반드시 export 하거나
# .env 에 비주석 상태로 넣고 `set -a; source .env; set +a` 로 로드.
# CI/CD(GitHub Actions)에서는 같은 값을 Secret/Variable 로 관리.
# =============================================================================

# [필수] ACA 타겟 (GH Variables: ACA_RESOURCE_GROUP, ACA_CONTAINERAPPS_ENV)
# RESOURCE_GROUP=nanobody-designer-897d0b-rg
# CONTAINERAPPS_ENV=nanobody-aca-897d0b-env

# [필수] Azure Container Registry (GH Secrets: ACR_LOGIN_SERVER/USERNAME/PASSWORD)
# ACR_LOGIN_SERVER=shaperon.azurecr.io
# ACR_USERNAME=
# ACR_PASSWORD=''   # ACR admin 패스워드는 +, /, = 등 포함 → 단일따옴표 권장

# [필수] Service Bus
#   NAMESPACE: KEDA 스케일 룰 메타데이터에 주입 (GH Secret: SERVICE_BUS_NAMESPACE)
#   QUEUE_NAME: api/worker 환경변수로 주입 (required_var)
# SERVICE_BUS_NAMESPACE=nanobodydsb897d0b
# SERVICE_BUS_QUEUE_NAME=boltz2-predict-jobs

# [선택] az login 대체 — 로컬에서 `az login` 했다면 생략 가능
# AZURE_SUBSCRIPTION_ID=<subscription id>
